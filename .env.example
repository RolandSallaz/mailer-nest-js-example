# =========================

# MAIL CONFIG

# =========================

MAIL_HOST=smtp.yandex.ru

# 465 = SSL (secure=true)

# 587 = STARTTLS (secure=false)

MAIL_PORT=465

# optional: если не указан — будет определяться по порту

# true / false

MAIL_SECURE=true

MAIL_USER=your_email@yandex.ru
MAIL_PASSWORD=your_app_password

MAIL_FROM="No Reply" noreply@example.com

# =========================

# OPTIONAL

# =========================

# retry логика

MAIL_MAX_RETRIES=3
MAIL_RETRY_DELAY_MS=1000

# таймаут соединения

MAIL_CONNECTION_TIMEOUT=10000
MAIL_GREETING_TIMEOUT=5000
